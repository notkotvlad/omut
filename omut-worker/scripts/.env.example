# Cloudflare KV — для записи снапшотов гидропостов
# Найти в: dash.cloudflare.com → Workers & Pages → KV → OMUT_CACHE
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_KV_NAMESPACE_ID=891f7ad560724b8c89d16dc45744f7ed
CF_API_TOKEN=your_cloudflare_api_token_with_kv_edit_rights

# (Опционально) URL интерактивной карты Казгидромета
# По умолчанию: https://www.kazhydromet.kz/ru/gidrologia
# HYDRO_MAP_URL=https://www.kazhydromet.kz/ru/gidrologia

# (Опционально) путь к Chrome/Chromium, если не в PATH
# PUPPETEER_EXECUTABLE=/usr/bin/google-chrome-stable

# Установить "1" чтобы запустить без реальной записи в KV (для отладки)
# DRY_RUN=1
